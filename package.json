{
  "name": "devai-assistant",
  "displayName": "DevAI – AI Coding Assistant",
  "description": "Production-grade AI coding assistant powered by Claude. Generate, debug, explain and refactor code with live web search.",
  "version": "1.0.0",
  "publisher": "devai-studio",
  "license": "MIT",
  "icon": "assets/icon.png",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "AI",
    "Programming Languages",
    "Machine Learning",
    "Other"
  ],
  "keywords": [
    "ai",
    "claude",
    "copilot",
    "autocomplete",
    "codegen",
    "chatgpt",
    "anthropic"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "devai-sidebar",
          "title": "DevAI",
          "icon": "assets/sidebar-icon.svg"
        }
      ]
    },
    "views": {
      "devai-sidebar": [
        {
          "type": "webview",
          "id": "devai.chatView",
          "name": "Chat",
          "visibility": "visible"
        }
      ]
    },
    "commands": [
      {
        "command": "devai.openChat",
        "title": "DevAI: Open Chat"
      },
      {
        "command": "devai.explainCode",
        "title": "DevAI: Explain Selected Code"
      },
      {
        "command": "devai.generateCode",
        "title": "DevAI: Generate Code from Comment"
      },
      {
        "command": "devai.debugCode",
        "title": "DevAI: Debug / Fix Selected Code"
      },
      {
        "command": "devai.refactorCode",
        "title": "DevAI: Refactor Selected Code"
      },
      {
        "command": "devai.generateTests",
        "title": "DevAI: Generate Unit Tests"
      },
      {
        "command": "devai.addComments",
        "title": "DevAI: Add JSDoc / Comments"
      },
      {
        "command": "devai.clearHistory",
        "title": "DevAI: Clear Chat History"
      },
      {
        "command": "devai.setApiKey",
        "title": "DevAI: Set Claude API Key"
      },
      {
        "command": "devai.pickModel",
        "title": "DevAI: Switch Ollama Model"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "when": "editorHasSelection",
          "submenu": "devai.contextMenu",
          "group": "1_devai"
        }
      ],
      "devai.contextMenu": [
        {
          "command": "devai.explainCode",
          "group": "1@1"
        },
        {
          "command": "devai.debugCode",
          "group": "1@2"
        },
        {
          "command": "devai.refactorCode",
          "group": "1@3"
        },
        {
          "command": "devai.generateTests",
          "group": "1@4"
        },
        {
          "command": "devai.addComments",
          "group": "1@5"
        }
      ],
      "editor/title": [
        {
          "command": "devai.openChat",
          "group": "navigation",
          "when": "editorIsOpen"
        }
      ]
    },
    "submenus": [
      {
        "id": "devai.contextMenu",
        "label": "DevAI ✦"
      }
    ],
    "keybindings": [
      {
        "command": "devai.openChat",
        "key": "ctrl+shift+a",
        "mac": "cmd+shift+a"
      },
      {
        "command": "devai.explainCode",
        "key": "ctrl+shift+e",
        "mac": "cmd+shift+e",
        "when": "editorHasSelection"
      },
      {
        "command": "devai.generateCode",
        "key": "ctrl+shift+g",
        "mac": "cmd+shift+g"
      },
      {
        "command": "devai.debugCode",
        "key": "ctrl+shift+d",
        "mac": "cmd+shift+d",
        "when": "editorHasSelection"
      },
      {
        "command": "devai.refactorCode",
        "key": "ctrl+shift+r",
        "mac": "cmd+shift+r",
        "when": "editorHasSelection"
      }
    ],
    "configuration": {
      "title": "DevAI",
      "properties": {
        "devai.ollamaHost": {
          "type": "string",
          "default": "http://localhost:11434",
          "description": "Ollama server URL (default: http://localhost:11434)"
        },
        "devai.ollamaModel": {
          "type": "string",
          "default": "qwen2.5-coder:7b",
          "description": "Ollama model to use. Run: ollama list"
        },
        "devai.enableInlineCompletion": {
          "type": "boolean",
          "default": true,
          "description": "Enable inline ghost-text completions (Tab to accept)"
        },
        "devai.inlineCompletionDelay": {
          "type": "number",
          "default": 800,
          "minimum": 300,
          "maximum": 3000,
          "description": "Debounce delay (ms) before triggering inline completions"
        },
        "devai.maxTokens": {
          "type": "number",
          "default": 2048,
          "minimum": 256,
          "maximum": 8192,
          "description": "Maximum tokens for AI responses"
        },
        "devai.contextLines": {
          "type": "number",
          "default": 100,
          "minimum": 20,
          "maximum": 500,
          "description": "Lines of surrounding code sent as context to AI"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build:prod",
    "build": "node esbuild.js",
    "build:prod": "node esbuild.js --production",
    "watch": "node esbuild.js --watch",
    "lint": "eslint src --ext ts",
    "package": "vsce package",
    "publish": "vsce publish"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^2.22.0",
    "esbuild": "^0.20.0",
    "eslint": "^8.56.0",
    "@typescript-eslint/parser": "^6.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "node-fetch": "^3.3.2"
  }
}